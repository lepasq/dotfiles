" VISUAL "

set number 
set relativenumber
set laststatus=2


" EDITS "

syntax on
filetype on
filetype indent on
filetype plugin on

set autoindent
set expandtab
set shiftwidth=4
set softtabstop=4

" SEARCH "

set ignorecase
set smartcase
set incsearch
set hlsearch


" KEYBINDINGS "

set backspace=indent,eol,start
nmap Q <Nop>

