#!/bin/sh

[ -z "$1" ] && {
    books "$HOME/Documents/books/"
    exit
}

[ "$1" = "-a" ] && {
    book=$(find "$HOME/Documents/books/" | dmenu -i -l 30)
    zathura "$book"
    exit
}

book=$(find "$1" -maxdepth 1 | dmenu -i -l 30)

[ -d "$book" ] && {
    books "$book"
    exit
}


[ -f "$book" ] && {
    zathura "$book"
    exit
}
