#!/usr/bin/env python3

# pip3 install PyPDF2

"""
 " Takes in the .pdf files to be merged
 " as well as the result name (without .pdf at the end!)
 " and merges them. The order is irrelevant
"""

from PyPDF2 import PdfFileReader, PdfFileWriter
import sys

def merge_pdfs():
    pdf_writer = PdfFileWriter()
    for file in get_pdfs():
        pdf_reader = PdfFileReader(file)
        for page in range(pdf_reader.getNumPages()):
            pdf_writer.addPage(pdf_reader.getPage(page))
    print('Merged PDFs.')
    with open(get_result_name(), 'wb') as out:
        pdf_writer.write(out)
        print('PDF file was created successfully.')


def get_result_name():
    for arg in sys.argv[1:]:
        if(arg[-3:] != "pdf"):
            print("file named " + arg)
            return arg + ".pdf"
    print("file named unnamed")
    return "unnamed.pdf"


def get_pdfs():
    list = []
    for arg in sys.argv[1:]:
        if(arg[-3:] == "pdf"):
            list.append(arg)
    return list

merge_pdfs()
